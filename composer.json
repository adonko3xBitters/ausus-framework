{
    "name": "ausus/monorepo",
    "type": "project",
    "description": "AUSUS 2.0 — official Entity Engine workspace. Resolves the Gen2 ausus/* packages from local path repositories at 2.0.0. The Legacy 1.x packages remain present in the repository but are no longer built or resolved by this workspace.",
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "packages/kernel",                "options": { "symlink": true, "versions": { "ausus/kernel":               "2.0.0" } } },
        { "type": "path", "url": "packages/entity-engine",         "options": { "symlink": true, "versions": { "ausus/entity-engine":        "2.0.0" } } },
        { "type": "path", "url": "packages/authoring",             "options": { "symlink": true, "versions": { "ausus/authoring":            "2.0.0" } } },
        { "type": "path", "url": "packages/persistence-memory",    "options": { "symlink": true, "versions": { "ausus/persistence-memory":   "2.0.0" } } },
        { "type": "path", "url": "packages/persistence-sqlite",    "options": { "symlink": true, "versions": { "ausus/persistence-sqlite":   "2.0.0" } } },
        { "type": "path", "url": "packages/api-runtime",           "options": { "symlink": true, "versions": { "ausus/api-runtime":          "2.0.0" } } },
        { "type": "path", "url": "packages/view-system",           "options": { "symlink": true, "versions": { "ausus/view-system":          "2.0.0" } } },
        { "type": "path", "url": "packages/cli",                   "options": { "symlink": true, "versions": { "ausus/cli":                  "2.0.0" } } }
    ],
    "require": {
        "php": ">=8.3",
        "ausus/api-runtime": "^2.0",
        "ausus/authoring": "^2.0",
        "ausus/cli": "^2.0",
        "ausus/entity-engine": "^2.0",
        "ausus/kernel": "^2.0",
        "ausus/persistence-memory": "^2.0",
        "ausus/persistence-sqlite": "^2.0",
        "ausus/view-system": "^2.0",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1"
    },
    "autoload": {
        "classmap": []
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
