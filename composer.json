{
    "name": "ausus/monorepo",
    "type": "project",
    "description": "AUSUS monorepo — V0 publication-ready workspace. Resolves ausus/* packages from local path repositories; mirrors what Packagist will see post-publication.",
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "packages/kernel",                "options": { "symlink": true, "versions": { "ausus/kernel":               "0.2.999" } } },
        { "type": "path", "url": "packages/persistence-sql",       "options": { "symlink": true, "versions": { "ausus/persistence-sql":      "0.2.999" } } },
        { "type": "path", "url": "packages/runtime-default",       "options": { "symlink": true, "versions": { "ausus/runtime-default":      "0.2.999" } } },
        { "type": "path", "url": "packages/api-http",              "options": { "symlink": true, "versions": { "ausus/api-http":             "0.2.999" } } },
        { "type": "path", "url": "packages/tenancy-row",           "options": { "symlink": true, "versions": { "ausus/tenancy-row":          "0.2.999" } } },
        { "type": "path", "url": "packages/audit-database",        "options": { "symlink": true, "versions": { "ausus/audit-database":       "0.2.999" } } },
        { "type": "path", "url": "packages/auth-bridge",           "options": { "symlink": true, "versions": { "ausus/auth-bridge":          "0.2.999" } } },
        { "type": "path", "url": "packages/presentation-default",  "options": { "symlink": true, "versions": { "ausus/presentation-default": "0.2.999" } } },
        { "type": "path", "url": "packages/standard-stack",        "options": { "symlink": true, "versions": { "ausus/standard-stack":       "0.2.999" } } },
        { "type": "path", "url": "packages/starter",               "options": { "symlink": true, "versions": { "ausus/starter":              "0.2.999" } } }
    ],
    "require": {
        "php": ">=8.3",
        "ausus/kernel":               "^0.2@alpha",
        "ausus/persistence-sql":      "^0.2@alpha",
        "ausus/runtime-default":      "^0.2@alpha",
        "ausus/api-http":             "^0.2@alpha",
        "ausus/standard-stack":       "^0.2@alpha",
        "ausus/starter":              "^0.2@alpha",
        "nyholm/psr7":                "^1.8",
        "nyholm/psr7-server":         "^1.1"
    },
    "autoload": {
        "classmap": ["apps/playground", "apps/issue-tracker/src"]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
