{
  "name": "@ausus/renderer-react",
  "version": "0.2.0-alpha.4",
  "description": "AUSUS React renderer — consumes RFC-004 ViewSchema JSON. React 18+, no third-party UI deps.",
  "license": "MIT",
  "type": "module",
  "main":    "./dist/index.js",
  "module":  "./dist/index.js",
  "types":   "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":  "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types":  "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build":          "rm -rf dist && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react":     "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerSchemaVersion": "^1.0.0",
  "devDependencies": {
    "@types/react":     "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript":       "^6.0.3"
  },
  "keywords": ["ausus", "react", "renderer", "viewschema"],
  "homepage": "https://github.com/ausus-framework/ausus",
  "repository": {
    "type": "git",
    "url":  "https://github.com/ausus-framework/ausus.git",
    "directory": "renderer/react"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
