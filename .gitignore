# ── Composer ─────────────────────────────────────────────────────────────
/vendor/
packages/*/vendor/
apps/*/vendor/
.composer-cache/
.phpunit.result.cache
.phpstan-cache/
.php-cs-fixer.cache

# ── npm / Node ───────────────────────────────────────────────────────────
node_modules/
renderer/react/node_modules/
apps/playground/web/node_modules/

# ── Build artifacts ──────────────────────────────────────────────────────
renderer/react/dist/
apps/playground/web/dist/
packages/react-renderer/dist/
*.tsbuildinfo

# ── AUSUS generated artifacts (RFC-011/012 compile output + test fixtures) ──
# `.ausus/` is the content-addressed compile output (schemas/<hash>.json + index.json),
# regenerated by `ausus compile`. App test fixtures are regenerated by the
# validation tests (run the *-validation-test.php before the *.test.ts).
.ausus/
apps/*/tests/.fixtures/

# ── Runtime / playground state ───────────────────────────────────────────
apps/playground/*.sqlite
*.sqlite
*.sqlite-journal
*.log
# Release evidence logs are intentionally committed (see
# scripts/archive-release-evidence.sh) so postmortem/replay/audit does not
# depend on ephemeral CI run retention.
!artifacts/releases/**/*.log

# ── Editor / OS ──────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*~

# ── Local-only ───────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
/tmp/
.composer/

# ── Local assistant scaffolding (not source-of-truth) ────────────────────
.claude/
CLAUDE.md
AGENTS.md
*.pdf
