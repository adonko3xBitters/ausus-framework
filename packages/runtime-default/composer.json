{
    "name": "ausus/runtime-default",
    "type": "library",
    "description": "L2 Runtime — Invoker, Policy Engine, Workflow runtime, Effect dispatch. Implements RFC-005 §3–§13, RFC-006, RFC-001 §A-1.4 §8.2.1, and the de facto ActionEffect dispatch of RFC-013.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "runtime", "invoker", "workflow"],
    "homepage": "https://github.com/ausus-framework/ausus",
    "require": {
        "php": ">=8.3",
        "ausus/kernel": "0.1.*"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Runtime\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L2",
            "role": "runtime"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
