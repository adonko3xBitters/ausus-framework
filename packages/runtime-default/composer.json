{
    "name": "ausus/runtime-default",
    "type": "library",
    "version": "0.1.0",
    "description": "L2 Runtime \u2014 Invoker, Policy Engine, Workflow runtime, Effect dispatch. Implements RFC-005 \u00a73\u2013\u00a713, RFC-006, RFC-001 \u00a7A-1.4 \u00a78.2.1, and the de facto ActionEffect dispatch of RFC-013.",
    "license": "MIT",
    "keywords": [
        "ausus",
        "framework",
        "runtime",
        "invoker",
        "workflow"
    ],
    "homepage": "https://github.com/ausus-framework/ausus",
    "require": {
        "php": ">=8.3",
        "ausus/kernel": "0.1.*"
    },
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Runtime\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L2",
            "role": "runtime"
        }
    },
    "archive": {
        "exclude": [
            "/tests",
            "/.gitkeep",
            "/.DS_Store"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
