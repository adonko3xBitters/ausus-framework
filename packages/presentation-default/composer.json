{
    "name": "ausus/presentation-default",
    "type": "library",
    "version": "0.1.0",
    "description": "AUSUS \u2014 L5 Presentation + L3 ReportingDriver + standard field types (RFC-004, RFC-010, RFC-012 \u00a77/\u00a78). Skeleton: name reserved; ProjectionRenderer is V0-shipped inside ausus/runtime-default.",
    "license": "MIT",
    "keywords": [
        "ausus",
        "framework",
        "presentation",
        "viewschema"
    ],
    "homepage": "https://github.com/ausus-framework/ausus",
    "require": {
        "php": ">=8.3"
    },
    "extra": {
        "ausus": {
            "layer": "L5",
            "role": "presentation",
            "status": "skeleton",
            "implementation-rfc": "RFC-004"
        }
    },
    "archive": {
        "exclude": [
            "/tests",
            "/.gitkeep",
            "/.DS_Store"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
