{
    "name": "ausus/standard-stack",
    "type": "library",
    "version": "0.1.0",
    "description": "AUSUS — the V0 Standard Stack: bundles kernel + persistence-sql + runtime-default + api-http and ships the high-level Ausus\\Application bootstrap facade. Skeleton packages (tenancy-row, audit-database, auth-bridge, presentation-default) will be added as their RFC-12 §16 implementations land.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "stack", "bootstrap", "application"],
    "homepage": "https://github.com/adonko3xBitters/ausus-framework",
    "require": {
        "php": ">=8.3",
        "ausus/kernel":           "0.1.*",
        "ausus/runtime-default":  "0.1.*",
        "ausus/persistence-sql":  "0.1.*",
        "ausus/api-http":         "0.1.*"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "extra": {
        "ausus": {
            "layer": "L5",
            "role": "stack",
            "v0-scope": ["ausus/kernel", "ausus/runtime-default", "ausus/persistence-sql", "ausus/api-http"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
