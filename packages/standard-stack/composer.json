{
    "name": "ausus/standard-stack",
    "type": "metapackage",
    "version": "0.1.0",
    "description": "AUSUS \u2014 meta-package installing the V0 Standard Stack (kernel + persistence-sql + runtime-default + api-http). Skeleton packages (tenancy-row, audit-database, auth-bridge, presentation-default) will be added as their RFC-12 \u00a716 implementations land.",
    "license": "MIT",
    "keywords": [
        "ausus",
        "framework",
        "stack"
    ],
    "homepage": "https://github.com/adonko3xBitters/ausus-framework",
    "require": {
        "php": ">=8.3",
        "ausus/kernel": "0.1.*",
        "ausus/runtime-default": "0.1.*",
        "ausus/persistence-sql": "0.1.*",
        "ausus/api-http": "0.1.*"
    },
    "extra": {
        "ausus": {
            "role": "meta",
            "v0-scope": [
                "ausus/kernel",
                "ausus/runtime-default",
                "ausus/persistence-sql",
                "ausus/api-http"
            ]
        }
    },
    "archive": {
        "exclude": [
            "/tests",
            "/.gitkeep",
            "/.DS_Store"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
