{
    "name": "ausus/starter",
    "type": "project",
    "description": "AUSUS V0 starter template — boots a working HelloInvoice demo on top of the Standard Stack via Ausus\\Application. Installs via `composer create-project ausus/starter myapp`.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "starter", "scaffold"],
    "homepage": "https://github.com/adonko3xBitters/starter",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ausus/kernel":           "^1.0",
        "ausus/persistence-sql":  "^1.0",
        "ausus/runtime-default":  "^1.0",
        "ausus/standard-stack":   "^1.0"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php bin/boot.php"
        ],
        "boot":  "@php bin/boot.php",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@php -S localhost:8000 bin/server.php"
        ]
    },
    "scripts-descriptions": {
        "boot":  "Bootstrap the starter end-to-end (DRAFT → ISSUED smoke).",
        "serve": "Start the built-in dev server at http://localhost:8000 (Ctrl+C to stop)."
    },
    "bin": ["bin/boot.php"],
    "extra": {
        "ausus": {
            "layer": "L7",
            "role": "template"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
