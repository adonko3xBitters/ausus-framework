{
    "name": "ausus/starter",
    "type": "project",
    "version": "0.1.0",
    "description": "AUSUS V0 starter template — boots a working HelloInvoice demo on top of the Standard Stack via Ausus\\Application. Installs via `composer create-project ausus/starter myapp`.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "starter", "scaffold"],
    "homepage": "https://github.com/ausus-framework/ausus",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ausus/kernel":           "0.1.*",
        "ausus/persistence-sql":  "0.1.*",
        "ausus/runtime-default":  "0.1.*",
        "ausus/standard-stack":   "0.1.*"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "scripts": {
        "post-root-package-install": [
            "@php bin/configure-repo.php"
        ],
        "post-create-project-cmd": [
            "@php bin/boot.php"
        ],
        "boot": "@php bin/boot.php"
    },
    "bin": ["bin/boot.php"],
    "extra": {
        "ausus": {
            "layer": "L7",
            "role": "template"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
