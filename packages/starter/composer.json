{
    "name": "ausus/starter",
    "type": "project",
    "description": "AUSUS V0 starter template — boots a working HelloInvoice demo on top of the Standard Stack via Ausus\\Application. Installs via `composer create-project ausus/starter myapp`.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "starter", "scaffold"],
    "homepage": "https://github.com/adonko3xBitters/starter",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ausus/kernel":           "^0.2@alpha",
        "ausus/persistence-sql":  "^0.2@alpha",
        "ausus/runtime-default":  "^0.2@alpha",
        "ausus/standard-stack":   "^0.2@alpha"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php bin/boot.php"
        ],
        "boot": "@php bin/boot.php"
    },
    "bin": ["bin/boot.php"],
    "extra": {
        "ausus": {
            "layer": "L7",
            "role": "template"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}
