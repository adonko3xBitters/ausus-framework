{
    "name": "ausus/authoring",
    "type": "library",
    "description": "AUSUS Authoring (L1) — closed PHP DSL producing RFC-012 EntityDefinition. RFC-CLI-002/003.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "authoring", "dsl"],
    "require": {
        "php": ">=8.3",
        "ausus/kernel": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ausus\\Authoring\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Authoring\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L1",
            "role": "authoring"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
