{
  "name": "@ausus/react-renderer",
  "version": "2.0.0",
  "description": "AUSUS L5 React Renderer — renders entities, projections and actions discovered from the api-runtime HTTP contract only. No knowledge of kernel/engine/compiler/repository.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adonko3xBitters/ausus-framework.git",
    "directory": "packages/react-renderer"
  },
  "homepage": "https://github.com/adonko3xBitters/ausus-framework",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "node --test --experimental-strip-types tests/*.test.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "keywords": ["ausus", "react", "renderer", "api-runtime"],
  "engines": {
    "node": ">=18"
  },
  "ausus": {
    "layer": "L5",
    "role": "renderer",
    "consumes": "api-runtime (HTTP contract only)"
  }
}
