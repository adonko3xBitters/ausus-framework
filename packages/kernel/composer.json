{
    "name": "ausus/kernel",
    "type": "library",
    "version": "0.1.0",
    "description": "AUSUS Kernel \u2014 contracts, value objects, DSL facade. RFC-001 + contract surfaces of RFC-005 \u00a72, RFC-013 \u00a72, RFC-014 \u00a72.",
    "license": "MIT",
    "keywords": [
        "ausus",
        "framework",
        "metadata",
        "kernel"
    ],
    "homepage": "https://github.com/ausus-framework/ausus",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Kernel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L0",
            "role": "kernel"
        }
    },
    "archive": {
        "exclude": [
            "/tests",
            "/.gitkeep",
            "/.DS_Store"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
