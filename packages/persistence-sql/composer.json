{
    "name": "ausus/persistence-sql",
    "type": "library",
    "description": "L3 PersistenceDriver — SQL implementation of RFC-002 via PDO (SQLite/MySQL/Postgres). Includes SchemaDeriver + DatabaseAuditSink.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "persistence", "sql", "pdo"],
    "homepage": "https://github.com/adonko3xBitters/persistence-sql",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ausus/kernel": "^0.2@alpha"
    },
    "suggest": {
        "ext-pdo_sqlite": "Default driver for V0 smoke tests",
        "ext-pdo_mysql":  "For MySQL deployments",
        "ext-pdo_pgsql":  "For PostgreSQL deployments"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Persistence\\Sql\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L3",
            "role": "driver"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
